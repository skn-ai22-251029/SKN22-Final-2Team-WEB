# 🐳 Docker Compose 로컬 환경변수 설정
# 
# 이 파일은 로컬 Docker Compose 실행 시 필요한 환경변수를 정의합니다.
# 
# [사용 방법]
# docker-compose -f infra/docker-compose.yml --env-file infra/.env up
#
# [주의사항]
# - 이 파일은 로컬 개발 환경용입니다
# - 프로덕션 값은 배포 시 자동으로 GitHub Secrets에서 로드됩니다
# - 민감한 정보(비밀번호, API 키)는 이 예제 파일에 입력하지 마세요

# ═══════════════════════════════════════════════════════════════════════════
# 🔗 PostgreSQL 데이터베이스 (Docker Compose 컨테이너)
# ═══════════════════════════════════════════════════════════════════════════

# 데이터베이스 호스트 (docker-compose 서비스명)
POSTGRES_HOST=postgres

# 데이터베이스 포트
POSTGRES_PORT=5432

# 데이터베이스 이름
POSTGRES_DB=tailtalk_db

# 데이터베이스 사용자명
POSTGRES_USER=mungnyang

# 데이터베이스 비밀번호 (로컬에서는 간단하게 설정 가능)
POSTGRES_PASSWORD=

# ═══════════════════════════════════════════════════════════════════════════
# 🔐 Django 보안 설정
# ═══════════════════════════════════════════════════════════════════════════

# Django SECRET_KEY (로컬 테스트용)
DJANGO_SECRET_KEY=local-dev-secret-key-not-for-production

# Django DEBUG 모드
DJANGO_DEBUG=True

# Django 허용 호스트
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# 보안 설정 (로컬에서는 비활성화)
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False

# ═════════════════════════════════════════════════════════════════════════════
# 🌐 애플리케이션 URL 설정
# ═════════════════════════════════════════════════════════════════════════════

# Django 기본 URL
APP_BASE_URL=http://localhost:8000

# FastAPI 내부 API 호출 URL (docker-compose 서비스명)
FASTAPI_INTERNAL_CHAT_URL=http://fastapi:8001/api/chat/

# 내부 서비스 토큰
INTERNAL_SERVICE_TOKEN=dev-internal-token

# CORS 허용 도메인
CORS_ALLOWED_ORIGINS=http://localhost

# ═════════════════════════════════════════════════════════════════════════════
# 🔌 Social OAuth (선택사항 - 로컬에서는 비워둬도 됨)
# ═════════════════════════════════════════════════════════════════════════════

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

SOCIAL_AUTH_REQUESTS_TIMEOUT=10

# ═════════════════════════════════════════════════════════════════════════════
# ☁️ AWS S3 (선택사항 - 로컬에서는 비워둬도 됨)
# ═════════════════════════════════════════════════════════════════════════════

AWS_S3_BUCKET_NAME=
AWS_S3_REGION_NAME=ap-northeast-2
AWS_S3_CUSTOM_DOMAIN=
AWS_S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ═════════════════════════════════════════════════════════════════════════════
# 🤖 FastAPI 설정
# ═════════════════════════════════════════════════════════════════════════════

# FastAPI 환경
FASTAPI_ENV=development

# OpenAI API 키 (선택사항 - 로컬에서는 비워둬도 됨)
OPENAI_API_KEY=

# LangSmith 트레이싱
LANGSMITH_TRACING=false

# LangSmith API 키 (선택사항)
LANGSMITH_API_KEY=

# LangSmith 프로젝트명
LANGSMITH_PROJECT=tailtalk-fastapi-local

# LangSmith API 엔드포인트
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# LangSmith 워크스페이스 ID (선택사항)
LANGSMITH_WORKSPACE_ID=
