# 🌍 Django 서비스 환경설정 파일
# 
# 이 파일은 Django 애플리케이션 실행 시 필요한 환경변수를 정의합니다.
# 
# [사용 위치]
# 1. 로컬 개발: services/django/.env (이 파일의 복사본)
# 2. Docker Compose: deploy/local/.env에서도 일부 변수가 공유됨
# 3. EB 배포: CI/CD가 생성한 .env 파일에서 로드됨
#
# [배포 환경별 설정]
# - 로컬 개발: 아래 값들을 로컬에 맞게 수정해서 사용
# - 배포 환경: GitHub Secrets에서 읽어서 자동 생성됨

# ═══════════════════════════════════════════════════════════════════════════
# 🔗 PostgreSQL 데이터베이스 설정
# ═══════════════════════════════════════════════════════════════════════════

# 데이터베이스 호스트
# [로컬]: localhost (로컬 PC에서 실행)
#         또는 postgres (docker-compose 컨테이너 이름)
# [배포]: 프로덕션 RDS 엔드포인트 (GitHub Secrets에서 로드)
POSTGRES_HOST=localhost

# 데이터베이스 포트 (기본값: 5432)
POSTGRES_PORT=5432

# 데이터베이스 이름
# [로컬]: 자유롭게 설정 (보통 tailtalk_db)
# [배포]: GitHub Secrets의 POSTGRES_DB 값 사용
POSTGRES_DB=tailtalk_db

# 데이터베이스 사용자명
# [로컬]: 간단한 테스트 사용자명 (예: mungnyang)
# [배포]: GitHub Secrets의 POSTGRES_USER 값 사용
POSTGRES_USER=mungnyang

# 데이터베이스 비밀번호
# [로컬]: 로컬에서는 보안 불필요 (빈칸 또는 간단한 값)
# [배포]: GitHub Secrets의 POSTGRES_PASSWORD 값 사용 (매우 중요!)
POSTGRES_PASSWORD=

# ═══════════════════════════════════════════════════════════════════════════
# 🔐 Django 보안 설정
# ═══════════════════════════════════════════════════════════════════════════

# Django SECRET_KEY (평문 저장 금지!)
# [로컬]: 로컬 테스트용 간단한 값
# [배포]: GitHub Secrets의 DJANGO_SECRET_KEY 값 사용 (매우 중요!)
DJANGO_SECRET_KEY=local-dev-secret-key-change-in-production

# Django DEBUG 모드 (개발/배포 환경 판별)
# [로컬]: True (상세한 에러 메시지)
# [배포]: False (보안상 반드시 False로!)
DJANGO_DEBUG=True

# Django 허용된 호스트
# [로컬]: localhost,127.0.0.1
# [배포]: 실제 도메인 또는 EB 엔드포인트 (예: *.elasticbeanstalk.com)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# 보안: SSL 리다이렉트
# [로컬]: False (로컬에서는 HTTPS 불필요)
# [배포]: True (HTTPS 강제)
DJANGO_SECURE_SSL_REDIRECT=False

# 보안: 세션 쿠키 HTTPS 전송
# [로컬]: False
# [배포]: True
DJANGO_SESSION_COOKIE_SECURE=False

# 보안: CSRF 쿠키 HTTPS 전송
# [로컬]: False
# [배포]: True
DJANGO_CSRF_COOKIE_SECURE=False

# CSRF 신뢰 도메인 (https 스킴 포함, 쉼표로 구분)
# [로컬]: 비워둬도 됨
# [배포]: https://tailtalk.store,https://www.tailtalk.store
DJANGO_CSRF_TRUSTED_ORIGINS=

# ═══════════════════════════════════════════════════════════════════════════
# 🌐 애플리케이션 URL 설정
# ═══════════════════════════════════════════════════════════════════════════

# 애플리케이션 기본 URL (프론트엔드 URL 등에 사용)
# [로컬]: http://localhost:8000 (로컬 Django 서버)
#         또는 http://localhost:3000 (프론트엔드 서버)
# [배포]: http://test-tailtalk-django-env.ap-northeast-2.elasticbeanstalk.com
APP_BASE_URL=http://localhost:8000

# Google Analytics 4 측정 ID
# [로컬]: 비워두면 GA 수집 비활성화
# [배포]: 실제 GA4 Measurement ID (예: G-XXXXXXXXXX)
GOOGLE_ANALYTICS_MEASUREMENT_ID=

# FastAPI 내부 채팅 API URL (Django에서 FastAPI 호출)
# [로컬]: http://fastapi:8001/api/chat/ (docker-compose 서비스명)
# [배포]: http://test-tailtalk-fastapi-env.ap-northeast-2.elasticbeanstalk.com/api/chat/
FASTAPI_INTERNAL_CHAT_URL=http://fastapi:8001/api/chat/

# 내부 서비스 토큰 (Django↔FastAPI 통신 인증)
# [로컬]: dev-internal-token (테스트용)
# [배포]: 실제 토큰 값 (GitHub Secrets)
INTERNAL_SERVICE_TOKEN=dev-internal-token

# ═══════════════════════════════════════════════════════════════════════════
# 🌍 CORS 설정 (Cross-Origin 요청 허용)
# ═══════════════════════════════════════════════════════════════════════════

# CORS 허용 도메인 (쉼표로 구분)
# [로컬]: http://localhost,http://localhost:3000,http://127.0.0.1
# [배포]: 실제 도메인들
CORS_ALLOWED_ORIGINS=http://localhost

# ═══════════════════════════════════════════════════════════════════════════
# ☁️ AWS S3 설정 (스토리지)
# ═══════════════════════════════════════════════════════════════════════════

# S3 버킷 이름
# [로컬]: 비워둬도 됨 (S3 사용하지 않으면)
# [배포]: 실제 S3 버킷명 (GitHub Secrets)
AWS_S3_BUCKET_NAME=

# S3 리전
# [로컬, 배포 공통]: ap-northeast-2 (서울)
AWS_S3_REGION_NAME=ap-northeast-2

# S3 커스텀 도메인 (CloudFront CDN 사용 시)
# [로컬]: 비워둬도 됨
# [배포]: CloudFront 도메인 또는 S3 도메인 (GitHub Secrets)
AWS_S3_CUSTOM_DOMAIN=

# S3 커스텀 엔드포인트 (Minio 같은 S3 호환 스토리지)
# [로컬]: 비워둬도 됨
# [배포]: 비워둬도 됨 (표준 S3 사용 시)
AWS_S3_ENDPOINT_URL=

# AWS IAM 액세스 키
# [현재]: Django 런타임에서는 사용하지 않음
# [배포]: GitHub Actions 배포 자격증명으로만 관리 (.env에 넣지 않음)
# [향후]: S3 업로드 기능을 다시 켤 때는 IAM Role 우선 검토
AWS_ACCESS_KEY_ID=

# AWS IAM 시크릿 액세스 키
# [현재]: Django 런타임에서는 사용하지 않음
# [배포]: GitHub Actions 배포 자격증명으로만 관리 (.env에 넣지 않음)
# [향후]: S3 업로드 기능을 다시 켤 때는 IAM Role 우선 검토
AWS_SECRET_ACCESS_KEY=

# ═══════════════════════════════════════════════════════════════════════════
# 🔌 Social OAuth 설정 (로그인)
# ═══════════════════════════════════════════════════════════════════════════

# Google OAuth
# [로컬]: 로컬 JSON 파일의 테스트용 ID
# [배포]: GitHub Secrets의 GOOGLE_CLIENT_ID 값 사용
GOOGLE_CLIENT_ID=

# [로컬]: 로컬 JSON 파일의 테스트용 SECRET
# [배포]: GitHub Secrets의 GOOGLE_CLIENT_SECRET 값 사용
GOOGLE_CLIENT_SECRET=

# Naver OAuth
NAVER_CLIENT_ID=

NAVER_CLIENT_SECRET=

# Kakao OAuth
KAKAO_CLIENT_ID=

KAKAO_CLIENT_SECRET=

# Social Auth 요청 타임아웃 (초)
SOCIAL_AUTH_REQUESTS_TIMEOUT=10

# ═══════════════════════════════════════════════════════════════════════════
# 📌 사용법
# ═══════════════════════════════════════════════════════════════════════════
#
# 1. 로컬 개발:
#    - 이 파일을 같은 디렉토리에 .env로 복사
#    - 로컬 환경에 맞게 값 수정 (주로 비밀번호)
#    - Docker Compose: docker compose -f deploy/local/docker-compose.yml up
#    - Django 직접 실행: python manage.py runserver
#
# 2. 배포:
#    - GitHub Secrets에 프로덕션 값 저장
#    - CI/CD가 자동으로 배포 .env 생성
#    - EB 환경변수로도 설정됨 (보조)
#
# 3. 환경변수 우선순위:
#    1순위: 배포 .env 파일 (GitHub Secrets에서 생성)
#    2순위: EB 콘솔에서 설정한 환경변수
#    3순위: Dockerfile ENV
